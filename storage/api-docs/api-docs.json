    "paths": {
        "/api/v1/register": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "1. Registro Inicial (Etapa 1)",
                "operationId": "03666f8b124ee27d07a3aa0e8e419f57",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "cpf_cnpj": {
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "google_id": {
                                        "type": "string",
                                        "example": "123456789kjooojjd01",
                                        "nullable": true
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "senha123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "senha123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado com sucesso"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
        "/api/v1/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "2. Autenticar usuário",
                "operationId": "88cd4b257048f26100832995c484d78b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "username": {
                                        "description": "CPF ou CNPJ",
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "senha123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado com sucesso"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    },
                    "403": {
                        "description": "Conta suspensa"
                    }
                }
            }
        },
        "/api/v1/complete-profile": {
            "post": {
                "tags": [
                    "Perfil"
                ],
                "summary": "3. Completar Cadastro (Etapa 2 - Endereço)",
                "operationId": "18765c94813254b5ae82ef223eaff7a8",
