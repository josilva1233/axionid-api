        "/api/v1/password/send-link": {
            "post": {
                "tags": [
                    "Recuperação de Senha"
                ],
                "summary": "1. Solicitar código de recuperação",
                "description": "Envia um código alfanumérico de 6 dígitos para o e-mail do usuário se ele existir no sistema.",
                "operationId": "05cf999d654365fd9ba3dea13d0cd829",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "usuario@email.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Código enviado com sucesso"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "500": {
                        "description": "Erro ao enviar e-mail"
                    }
                }
            }
        },
        "/api/v1/password/verify-code": {
            "post": {
                "tags": [
                    "Recuperação de Senha"
                ],
                "summary": "2. Verificar validade do código",
                "description": "Valida se o código de 6 dígitos informado ainda é válido e não expirou (limite de 60 min).",
                "operationId": "f85fa19e5ca3ac5b91d380d012486c54",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "usuario@email.com"
                                    },
                                    "token": {
                                        "type": "string",
                                        "example": "A1B2C3"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Código validado com sucesso"
                    },
                    "422": {
                        "description": "Código inválido ou expirado"
                    }
                }
            }
        },
